# ================================
# CONTROLE ATENDIMENTO ICONNECT
# Configurações de Ambiente
# ================================
# ATENÇÃO: Copie este arquivo para .env e preencha com valores reais.
# NUNCA comite o .env com credenciais reais!

# =============================================================================
# CONFIGURAÇÕES OBRIGATÓRIAS
# =============================================================================

# Chave secreta do Django - GERE UMA NOVA PARA PRODUÇÃO!
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-MUDE-ESTA-CHAVE-EM-PRODUCAO

# Ambiente de execução: development | production
ENVIRONMENT=development

# Debug (NUNCA use True em produção!)
DEBUG=True

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# BANCO DE DADOS (Docker Compose usa essas variáveis)
# =============================================================================
POSTGRES_DB=iconnect_db
POSTGRES_USER=iconnect_user
POSTGRES_PASSWORD=MUDE-PARA-UMA-SENHA-FORTE

# DATABASE_URL é montada automaticamente no docker-compose
# Para uso local sem Docker:
# DATABASE_URL=postgresql://iconnect_user:senha@localhost:5432/iconnect_db

# =============================================================================
# REDIS / CACHE / CELERY
# =============================================================================
REDIS_PASSWORD=MUDE-PARA-UMA-SENHA-FORTE
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# =============================================================================
# SUPERUSUÁRIO DJANGO (usado no docker-entrypoint)
# =============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=MUDE-PARA-UMA-SENHA-FORTE
DJANGO_SUPERUSER_EMAIL=admin@iconnect.com

# =============================================================================
# FLOWER (Monitor Celery)
# =============================================================================
FLOWER_USER=admin
FLOWER_PASSWORD=MUDE-PARA-UMA-SENHA-FORTE

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=Sistema iConnect <noreply@iconnect.com>

# Security Settings
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# AWS S3 Storage (opcional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=

# WhatsApp Integration
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Backup Settings
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
