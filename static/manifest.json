{
  "name": "iConnect - Sistema de Controle de Atendimento",
  "short_name": "iConnect",
  "description": "Sistema completo de controle de atendimento com chat integrado e gestão de tickets - Otimizado para técnicos de campo",
  "version": "1.0.0",
  "start_url": "/mobile/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#e91e63",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["business", "productivity", "utilities"],
  "screenshots": [
    {
      "src": "/static/pwa/screenshot-mobile-1.jpg",
      "sizes": "390x844",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "/static/pwa/screenshot-desktop-1.jpg", 
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide"
    }
  ],
  "icons": [
    {
      "src": "/static/img/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-96x96.png",
      "sizes": "96x96", 
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png", 
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "features": [
    "cross-origin-isolated"
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "Acesso rápido ao dashboard principal",
      "url": "/dashboard/",
      "icons": [
        {
          "src": "/static/img/icons/dashboard-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Chat",
      "short_name": "Chat",
      "description": "Acesso direto ao sistema de chat",
      "url": "/dashboard/chat/",
      "icons": [
        {
          "src": "/static/img/icons/chat-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Tickets",
      "short_name": "Tickets",
      "description": "Gestão de tickets de atendimento",
      "url": "/dashboard/tickets/",
      "icons": [
        {
          "src": "/static/img/icons/tickets-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Novo Ticket",
      "short_name": "Novo",
      "description": "Criar novo ticket rapidamente",
      "url": "/dashboard/tickets/new/",
      "icons": [
        {
          "src": "/static/img/icons/new-ticket-shortcut.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Mobile - Tickets",
      "short_name": "Mobile",
      "description": "Interface mobile para técnicos de campo",
      "url": "/mobile/tickets/",
      "icons": [
        {
          "src": "/static/img/icons/icon-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Mobile - Chat",
      "short_name": "Chat Mobile",
      "description": "Chat móvel para suporte",
      "url": "/mobile/chat/",
      "icons": [
        {
          "src": "/static/img/icons/icon-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "protocol_handlers": [
    {
      "protocol": "web+iconnect",
      "url": "/dashboard/?ticket=%s"
    }
  ],
  "share_target": {
    "action": "/dashboard/tickets/new/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "description",
      "url": "url",
      "files": [
        {
          "name": "attachment",
          "accept": ["image/*", "application/pdf", ".doc", ".docx", ".txt"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/dashboard/tickets/import/",
      "accept": {
        "text/csv": [".csv"],
        "application/vnd.ms-excel": [".xls"],
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"]
      }
    }
  ]
}
