{
  "name": "iConnect Mobile",
  "short_name": "iConnect",
  "description": "Sistema de Atendimento iConnect - Versão Mobile",
  "start_url": "/mobile/",
  "display": "standalone",
  "background_color": "#e91e63",
  "theme_color": "#e91e63",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["business", "productivity", "utilities"],
  "screenshots": [
    {
      "src": "/static/pwa/screenshot-mobile-1.jpg",
      "sizes": "390x844",
      "type": "image/jpeg",
      "form_factor": "narrow"
    },
    {
      "src": "/static/pwa/screenshot-desktop-1.jpg", 
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide"
    }
  ],
  "icons": [
    {
      "src": "/static/img/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-96x96.png",
      "sizes": "96x96", 
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png", 
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/static/img/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "features": [
    "cross-origin-isolated"
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "shortcuts": [
    {
      "name": "Novo Ticket",
      "description": "Criar um novo ticket de suporte",
      "url": "/mobile/ticket/new/",
      "icons": [
        {
          "src": "/static/img/icons/add-ticket.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Meus Tickets",
      "description": "Ver meus tickets de suporte", 
      "url": "/mobile/tickets/",
      "icons": [
        {
          "src": "/static/img/icons/my-tickets.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Chat Suporte",
      "description": "Conversar com o suporte",
      "url": "/mobile/chat/",
      "icons": [
        {
          "src": "/static/img/icons/chat.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/mobile/share/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", ".pdf", ".doc", ".docx", ".txt"]
        }
      ]
    }
  }
}
